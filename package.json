    "helmet": "^7.1.0",
    "multer": "^2.1.1",
    "qs": "^6.15.0",
    "uuid": "^8.3.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "concurrently": "^8.2.2"
  }
}
